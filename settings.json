{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(npm *)",
      "Write(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(gh pr *)",
      "Bash(gh search *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:npmjs.org)",
      "mcp__serena__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git push *--force*)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/*secret*)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development)",
      "Write(.env.production)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.development)",
      "Write(**/.env.production)",
      "Write(**/*secret*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(wget *)",
      "Bash(curl *)",
      "Bash(git merge *)",
      "Bash(gwq *)",
      "Bash(git checkout .)",
      "Bash(git checkout -- *)",
      "Bash(git checkout * -- *)"
    ]
  },
  "enabledPlugins": {
    "code-review@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "context7-plugin@context7-marketplace": true
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  }
}
